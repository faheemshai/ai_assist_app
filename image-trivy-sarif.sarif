          "rules": [
            {
              "id": "CVE-2026-25068",
              "name": "OsPackageVulnerability",
              "shortDescription": {
                "text": "alsa-lib: alsa-lib Topology Decoder Heap-based Buffer Overflow"
              },
              "fullDescription": {
                "text": "alsa-lib versions 1.2.2 up to and including 1.2.15.2, prior to commit 5f7fe33, contain a heap-based buffer overflow in the topology mixer control decoder. The tplg_decode_control_mixer1() function reads the num_channels field from untrusted .tplg data and uses it as a loop bound without validating it against the fixed-size channel array (SND_TPLG_MAX_CHAN). A crafted topology file with an excessive num_channels value can cause out-of-bounds heap writes, leading to a crash."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://avd.aquasec.com/nvd/cve-2026-25068",
              "help": {
                "text": "Vulnerability CVE-2026-25068\nSeverity: MEDIUM\nPackage: alsa-lib\nFixed Version: \nLink: [CVE-2026-25068](https://avd.aquasec.com/nvd/cve-2026-25068)\nalsa-lib versions 1.2.2 up to and including 1.2.15.2, prior to commit 5f7fe33, contain a heap-based buffer overflow in the topology mixer control decoder. The tplg_decode_control_mixer1() function reads the num_channels field from untrusted .tplg data and uses it as a loop bound without validating it against the fixed-size channel array (SND_TPLG_MAX_CHAN). A crafted topology file with an excessive num_channels value can cause out-of-bounds heap writes, leading to a crash.",
                "markdown": "**Vulnerability CVE-2026-25068**\n| Severity | Package | Fixed Version | Link |\n| --- | --- | --- | --- |\n|MEDIUM|alsa-lib||[CVE-2026-25068](https://avd.aquasec.com/nvd/cve-2026-25068)|\n\nalsa-lib versions 1.2.2 up to and including 1.2.15.2, prior to commit 5f7fe33, contain a heap-based buffer overflow in the topology mixer control decoder. The tplg_decode_control_mixer1() function reads the num_channels field from untrusted .tplg data and uses it as a loop bound without validating it against the fixed-size channel array (SND_TPLG_MAX_CHAN). A crafted topology file with an excessive num_channels value can cause out-of-bounds heap writes, leading to a crash."
              },
              "properties": {
                "cvssv3_baseScore": 4.3,
                "cvssv3_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:L",
                "precision": "very-high",
                "security-severity": "4.3",
                "tags": [
                  "vulnerability",
                  "security",
                  "MEDIUM"
                ]
              }
            },
            {
              "id": "CVE-2024-52615",
              "name": "OsPackageVulnerability",
              "shortDescription": {
                "text": "avahi: Avahi Wide-Area DNS Uses Constant Source Port"
              },
              "fullDescription": {
                "text": "A flaw was found in Avahi-daemon, which relies on fixed source ports for wide-area DNS queries. This issue simplifies attacks where malicious DNS responses are injected."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://avd.aquasec.com/nvd/cve-2024-52615",
